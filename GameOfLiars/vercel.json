{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gameofliars-production.up.railway.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://gameofliars-production.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
} 